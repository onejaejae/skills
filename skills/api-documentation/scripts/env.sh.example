#!/bin/bash
#
# API 문서화 스크립트 환경 설정
# 이 파일을 env.sh로 복사한 후 실제 값으로 수정하세요.
#
# cp env.sh.example env.sh
# vim env.sh
#

# Notion 설정
export NOTION_API_KEY="secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export NOTION_DATABASE_ID="2c7d87e517f480d88516e88afd3c2875"        # Re-AI API Database
export NOTION_TASKS_DATABASE_ID="a04b41f4f46e49d285cf04ce952db946"  # 태스크 Database (docs 페이지 생성용)
export NOTION_EPIC_ID="에픽-페이지-ID"  # 연결할 에픽 ID (선택, --create-docs 시 에픽에 자동 연결)

# Postman 설정
export POSTMAN_API_KEY="PMAK-xxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export POSTMAN_COLLECTION_ID="410bece5-689a-4fa5-babc-aa39887a59a8"
